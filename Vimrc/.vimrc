" ============================================================
" .vimrc - John's Vim Configuration
" ============================================================

" ----
" General
" ----
set nocompatible
set encoding=utf-8
set history=1000

" ----
" Display
" ----
set number
set relativenumber
set cursorline
set scrolloff=8
syntax on

" ----
" Indentation
" ----
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set autoindent

" ----
" Search
" ----
set incsearch
set hlsearch
set ignorecase
set smartcase

" ----
" Usability
" ----
set mouse=a
set clipboard=unnamed
set backspace=indent,eol,start
set showcmd
set showmode
set wildmenu